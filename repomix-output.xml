	// Load
	loaded, err := LoadMetadata(dir, "example.com")
	if err != nil {
		t.Fatalf("load failed: %v", err)
	}

	if loaded.Domain != site.Domain {
		t.Errorf("domain mismatch: got %s", loaded.Domain)
	}
	if loaded.User != site.User {
